{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "type": "local"
    },
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gitnexus": {
      "command": [
        "gitnexus",
        "mcp"
      ],
      "type": "local"
    }
  },
  "plugin": [
    "/Users/yelog/workspace/swift/VibeBar/plugins/opencode-vibebar-plugin"
  ],
  "provider": {
    "xrouter": {
      "models": {
        "codex-mini-latest": {
          "limit": {
            "context": 200000,
            "output": 100000
          },
          "name": "Codex Mini",
          "options": {
            "store": false
          },
          "variants": {
            "high": {},
            "low": {},
            "medium": {}
          }
        },
        "gpt-5.2": {
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "name": "GPT-5.2",
          "options": {
            "store": false
          },
          "variants": {
            "high": {},
            "low": {},
            "medium": {},
            "xhigh": {}
          }
        },
        "gpt-5.3-codex": {
          "limit": {
            "context": 400000,
