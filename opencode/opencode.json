{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "type": "local"
    },
    "codegraph": {
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "permission": "allow",
  "plugin": [
    "/Users/yelog/workspace/swift/VibeBar/plugins/opencode-vibebar-plugin"
  ],
  "provider": {
    "xrouter": {
      "models": {
        "gpt-4o": {
          "attachment": true,
          "cost": {
            "input": 0.33,
            "output": 2.64
          },
          "family": "gpt-4",
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "GPT 4o",
          "options": {
            "store": false
          },
          "reasoning": false,
          "release_date": "2026-04-01",
          "temperature": true,
