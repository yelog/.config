            "output": 32000
          },
          "name": "GPT-5.3 Codex Spark",
          "options": {
            "store": false
          },
          "variants": {
            "high": {},
            "low": {},
            "medium": {},
            "xhigh": {}
          }
        },
        "gpt-5.4": {
          "limit": {
