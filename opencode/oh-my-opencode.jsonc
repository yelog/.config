      "model": "anthropic/claude-opus-4-6"
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "librarian": {
      "model": "opencode/glm-4.7-free"
    },
    "metis": {
      "model": "kimi-for-coding/k2p5",
      "variant": "max"
    },
    "momus": {
      "model": "openai/gpt-5.2",
      "variant": "medium"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.2"
    },
    "oracle": {
      "model": "openai/gpt-5.2",
      "variant": "high"
    },
    "prometheus": {
      "model": "kimi-for-coding/k2p5",
      "variant": "max"
    },
    "sisyphus": {
      "model": "kimi-for-coding/k2p5"
    }
  },
  "categories": {
    "artistry": {
      "model": "github-copilot/gemini-3-pro",
      "variant": "max"
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "quick": {
      "model": "opencode/glm-4.7-free"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "visual-engineering": {
      "model": "kimi-for-coding/k2p5"
    },
    "writing": {
      "model": "kimi-for-coding/k2p5"
    }
  }
}