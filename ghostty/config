auto-update = download

# Theme
theme = TokyoNight Night

# Fonts
font-family = JetBrainsMono Nerd Font Mono
font-family-bold = JetBrainsMono NFM Bold
font-family-italic = JetBrainsMono NFM Italic
font-family-bold-italic = JetBrainsMono NFM Bold Italic
# 中文
font-codepoint-map = "U+4E00-U+9FFF,U+3400-U+4DBF = Source Han Sans HW S"
font-size = 14
# font-thicken = true

# Background
background = #000000
background-image = /Users/yelog/Documents/image/紫云黄昏漫画风.jpeg
background-image-fit = cover
background-image-opacity = 0.4

# Custom Shader (Cursor Trail Effect)
custom-shader = ~/.config/ghostty/shaders/cursor_smear.glsl

# Shell
shell-integration = zsh

# Mouse
mouse-hide-while-typing = true

# Window
window-padding-y = 2,0
window-padding-balance = true
# macos-titlebar-style = hidden

# keybindings
# super (alias: cmd, command)
# alt (alias: opt, option)
# ctrl (alias: control)
macos-option-as-alt = true

# Unbind keybindings to pass through to Zellij
# Pane focus movement: Cmd+Ctrl+hjkl
keybind = super+ctrl+h=unbind
keybind = super+ctrl+j=unbind
keybind = super+ctrl+k=unbind
keybind = super+ctrl+l=unbind

# Pane resizing: Cmd+Ctrl+Shift+hjkl
keybind = super+ctrl+shift+h=unbind
keybind = super+ctrl+shift+j=unbind
keybind = super+ctrl+shift+k=unbind
keybind = super+ctrl+shift+l=unbind

# Pane movement: Cmd+Ctrl+Opt+hjkl
keybind = super+ctrl+alt+h=unbind
keybind = super+ctrl+alt+j=unbind
keybind = super+ctrl+alt+k=unbind
keybind = super+ctrl+alt+l=unbind

# Pane fullscreen toggle: Cmd+Ctrl+f (send CSI u sequence to bypass macOS fullscreen)
keybind = super+ctrl+f=text:\x1b[102;13u

# Tab management
keybind = super+t=unbind
keybind = super+n=unbind
keybind = super+p=unbind
keybind = super+shift+n=unbind
keybind = super+shift+p=unbind
keybind = super+w=unbind

# Tab quick switch: Cmd+1~9 (send as Alt+1~9 CSI u sequence for zellij compatibility)
# Alt modifier = 2, so modifier value = 3 (2+1)
keybind = super+1=text:\x1b[49;3u
keybind = super+2=text:\x1b[50;3u
keybind = super+3=text:\x1b[51;3u
keybind = super+4=text:\x1b[52;3u
keybind = super+5=text:\x1b[53;3u
keybind = super+6=text:\x1b[54;3u
keybind = super+7=text:\x1b[55;3u
keybind = super+8=text:\x1b[56;3u
keybind = super+9=text:\x1b[57;3u
keybind = super+digit_1=text:\x1b[49;3u
keybind = super+digit_2=text:\x1b[50;3u
keybind = super+digit_3=text:\x1b[51;3u
keybind = super+digit_4=text:\x1b[52;3u
keybind = super+digit_5=text:\x1b[53;3u
keybind = super+digit_6=text:\x1b[54;3u
keybind = super+digit_7=text:\x1b[55;3u
keybind = super+digit_8=text:\x1b[56;3u

# Pane creation
keybind = super+enter=unbind
keybind = super+shift+enter=unbind

# Keep config reload
keybind = super+ctrl+r=reload_config
