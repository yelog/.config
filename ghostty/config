auto-update = download

# Theme
theme = TokyoNight Night

# Fonts
font-family = JetBrainsMono Nerd Font Mono
font-family-bold = JetBrainsMono NFM Bold
font-family-italic = JetBrainsMono NFM Italic
font-family-bold-italic = JetBrainsMono NFM Bold Italic
# 中文
font-codepoint-map = "U+4E00-U+9FFF,U+3400-U+4DBF = Source Han Sans HW S"
font-size = 16
# font-thicken = true

# Background
background = #000000
background-image = /Users/yelog/Documents/image/紫云黄昏漫画风.jpeg
background-image-fit = cover
background-image-opacity = 0.4

# Shell
shell-integration = zsh

# Mouse
mouse-hide-while-typing = true

# Window
window-padding-y = 2,0
window-padding-balance = true
macos-titlebar-style = hidden

# keybindings
# super (alias: cmd, command)
# alt (alias: opt, option)
# ctrl (alias: control)
macos-option-as-alt = true

# Unbind keybindings to pass through to Zellij
# Pane focus movement: Cmd+Ctrl+hjkl
keybind = super+ctrl+h=unbind
keybind = super+ctrl+j=unbind
keybind = super+ctrl+k=unbind
keybind = super+ctrl+l=unbind

# Pane resizing: Cmd+Ctrl+Shift+hjkl
keybind = super+ctrl+shift+h=unbind
keybind = super+ctrl+shift+j=unbind
keybind = super+ctrl+shift+k=unbind
keybind = super+ctrl+shift+l=unbind

# Pane movement: Cmd+Ctrl+Opt+hjkl
keybind = super+ctrl+alt+h=unbind
keybind = super+ctrl+alt+j=unbind
keybind = super+ctrl+alt+k=unbind
keybind = super+ctrl+alt+l=unbind

# Pane fullscreen toggle: Cmd+Ctrl+f (ignore to pass to Zellij)
keybind = super+ctrl+f=ignore

# Tab management
keybind = super+t=unbind
keybind = super+n=unbind
keybind = super+p=unbind
keybind = super+shift+n=unbind
keybind = super+shift+p=unbind
keybind = super+w=unbind

# Pane creation
keybind = super+enter=unbind
keybind = super+shift+enter=unbind

# Keep config reload
keybind = super+ctrl+r=reload_config
